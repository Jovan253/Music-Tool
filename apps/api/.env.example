# Backend server bind settings
API_HOST=0.0.0.0
API_PORT=8000

# Database (Railway injects DATABASE_URL automatically via the Postgres add-on)
DATABASE_URL=postgresql://musictool:musictool@localhost:5432/musictool

# Redis / RQ (Railway injects REDIS_URL automatically via the Redis add-on)
REDIS_URL=redis://localhost:6379/0
RQ_REDIS_URL=redis://localhost:6379/0

# Supabase Storage
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_ANON_KEY=<anon-key>

# Secret key for signing tokens (generate with: openssl rand -hex 32)
SECRET_KEY=change-me

# Comma-separated list of allowed CORS origins
# Production: set to your Vercel app URL, e.g. https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173

# Demucs inference device — auto-detected if not set (cuda when GPU present, cpu otherwise)
# Set to "cpu" on Railway starter/hobby tier (no GPU available)
DEMUCS_DEVICE=cpu
# DEMUCS_DEVICE=cuda  # assert GPU is available (job fails with clear error if no GPU)
