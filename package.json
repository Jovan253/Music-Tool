{
  "name": "music-tool",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "cd apps/api && uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "install:api": "cd apps/api && python -m venv .venv && .venv/Scripts/pip install -e ."
  }
}
